PROVENIX_ENVIRONMENT=development

PROVENIX_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/provenix
PROVENIX_REDIS_URL=redis://localhost:6379/0

# openssl rand -hex 32
PROVENIX_JWT_SECRET=change-me-to-a-32-byte-random-hex-string-0000

PROVENIX_ACCESS_TOKEN_TTL=900
PROVENIX_REFRESH_TOKEN_TTL=1209600

PROVENIX_REFRESH_COOKIE_SECURE=false
PROVENIX_REFRESH_COOKIE_SAMESITE=lax

PROVENIX_APP_URL=http://localhost:3000
PROVENIX_CORS_ORIGINS=["http://localhost:3000"]
