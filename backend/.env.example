PROVENIX_ENVIRONMENT=development

# Port 5433 matches infra/docker/docker-compose.yml, which publishes postgres there.
PROVENIX_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/provenix
PROVENIX_REDIS_URL=redis://localhost:6379/0

# openssl rand -hex 32
PROVENIX_JWT_SECRET=change-me-to-a-32-byte-random-hex-string-0000

PROVENIX_ACCESS_TOKEN_TTL=900
PROVENIX_REFRESH_TOKEN_TTL=1209600

PROVENIX_REFRESH_COOKIE_SECURE=false
PROVENIX_REFRESH_COOKIE_SAMESITE=lax

PROVENIX_APP_URL=http://localhost:3000
PROVENIX_CORS_ORIGINS=["http://localhost:3000"]

# MinIO from the compose stack. Use real credentials and a real endpoint anywhere else.
PROVENIX_S3_ENDPOINT=http://localhost:9000
PROVENIX_S3_ACCESS_KEY=minioadmin
PROVENIX_S3_SECRET_KEY=minioadmin
PROVENIX_S3_BUCKET=provenix

# Share of the price a Buy Now token payment reserves a property with.
PROVENIX_PURCHASE_TOKEN_PERCENT=10
